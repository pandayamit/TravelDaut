<% layout("layouts/boilerplate") -%>

    <div class="row mt-3">

        <div class="col-8 offset-3">
            <h3>Listing Details</h3>
        </div>
        <div class="card col-6 offset-3 show-card">
            <img src="<%= listingView.image %>" class="card-img-top show-img" alt="listing image">
            <div class="card-body">
                <p class="card-text">
                    <b>
                        <%= listingView.title %>
                    </b><br />
                    <%= listingView.description %> <br />
                        &#8377; <%= listingView.price.toLocaleString("en-IN") %> <br />
                            <%= listingView.location %> <br />
                                <%= listingView.country %>
                </p>
            </div>
        </div>

        <div class="btns mb-3">
            <a href="/listings/<%= listingView._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

            <form method="post" action="/listings/<%=listingView._id %>?_method=DELETE">
                <button class="btn btn-dark offset-5">
                    Delete
                </button>
            </form>
        </div>

    </div>