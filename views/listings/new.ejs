<% layout("layouts/boilerplate") -%>
    <div class="row">
        <div class="col-8 offset-2">
            <h3 class="mb-4">Create New Listing</h3>
            
            <form method="post" action="/listings" >
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" placeholder="Add a Catchy Title" name="listing[title]" required
                        class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea placeholder="Description" name="listing[description]" required
                        class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Image Link</label>
                    <input type="text" placeholder="enter image Url/link" name="listing[image]" class="form-control" />
                </div>

                <div class="row">

                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" placeholder="3300" name="listing[price]" required class="form-control" />
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" placeholder="India" name="listing[country]" required class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" placeholder="Lucknow,Uttar Pradesh" name="listing[location]" required
                        class="form-control" />
                </div>



                <button class="btn btn-dark mb-2 add-btn">Add</button>
            </form>
        </div>
    </div>